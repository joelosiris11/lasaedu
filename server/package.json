{
  "name": "lasaedu-file-server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "pm2:start": "pm2 start ecosystem.config.cjs --env production",
    "pm2:reload": "pm2 reload ecosystem.config.cjs --env production",
    "pm2:stop": "pm2 stop lasaedu-fileserver",
    "pm2:logs": "pm2 logs lasaedu-fileserver",
    "pm2:status": "pm2 status",
    "deploy": "git pull && npm ci --omit=dev && pm2 reload ecosystem.config.cjs --env production && pm2 save"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-async-errors": "^3.1.1",
    "firebase-admin": "^12.0.0",
    "jsonwebtoken": "^9.0.2",
    "minio": "^8.0.7",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^9.0.3",
    "pg": "^8.13.0",
    "puppeteer-core": "^23.0.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "pm2": "^5.4.0"
  }
}
