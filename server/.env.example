# File server environment — copy to `.env` on the VPS and fill in.
# This file is safe to commit; `.env` is git-ignored.

# Port the server listens on (behind nginx/caddy reverse proxy)
PORT=3010

# Absolute path to the upload directory on the VPS.
# Pick a path on a persistent disk and back it up.
UPLOAD_DIR=/var/lasaedu/uploads

# Public URL where this server is reachable (what the frontend receives
# as the file URL). Must be HTTPS in production.
BASE_URL=https://files.tudominio.com

# Comma-separated list of allowed origins (the frontend domains).
# No trailing slashes. Include every origin that calls this server.
ALLOWED_ORIGINS=https://lasaedurd.web.app,https://lasaedurd.firebaseapp.com

# Firebase project ID (used to verify user ID tokens).
FIREBASE_PROJECT_ID=lasaedurd

# Absolute path to the Firebase service-account JSON on the VPS.
# Keep this file OUTSIDE the repo, chmod 600.
GOOGLE_APPLICATION_CREDENTIALS=/opt/lasaedu/sa.json

# ── AI assistant: image generation (Gemini) ──────────────────────────────
# Used ONLY by POST /ai/image to generate images with Gemini (Nano Banana Pro).
# The key never reaches the browser. .env is git-ignored — never commit it.
GEMINI_API_KEY=
# Optional override (default: gemini-3-pro-image).
# GEMINI_IMAGE_MODEL=gemini-3-pro-image

# ── AI assistant: PDF reports (Puppeteer) ────────────────────────────────
# Path to the Chromium executable Puppeteer drives.
#   Docker (alpine):  /usr/bin/chromium-browser  (installed in the Dockerfile)
#   Native VPS:       run `apt install chromium` then point here
#                     (often /usr/bin/chromium or /usr/bin/chromium-browser)
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
