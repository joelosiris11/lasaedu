# ── Backend self-host LasaEdu (api.mjs) — copiar a server/.env en el VPS ──
# git-ignored. NO commitear con valores reales.

API_PORT=3020
ALLOWED_ORIGINS=https://lasaacademy.cloudteco.com
# URL pública del backend (para armar URLs de archivos). En prod = el dominio.
BASE_URL=https://lasaacademy.cloudteco.com

# ── PostgreSQL ──
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=lasaacademy
PGPASSWORD=            # ← pon una clave fuerte
PGDATABASE=lasaacademy
# o alternativamente: DATABASE_URL=postgres://user:pass@host:5432/db

# ── JWT (auth propia) ──
JWT_SECRET=            # ← 64+ chars aleatorios (openssl rand -base64 48)
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

# ── scrypt de Firebase (para verificar contraseñas migradas) ──
# Se obtienen con la API getConfig de Identity Toolkit del proyecto lasaedurd.
AUTH_SCRYPT_SIGNER_KEY=
AUTH_SCRYPT_SALT_SEPARATOR=Bw==
AUTH_SCRYPT_ROUNDS=8
AUTH_SCRYPT_MEM_COST=14

# ── MinIO (archivos) ──
MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=lasaacademy
MAX_UPLOAD_MB=500

# ── IA ──
OLLAMA_API_KEY=
OLLAMA_BASE_URL=https://ollama.com
VITE_OLLAMA_MODEL=kimi-k2.6:cloud
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-3-pro-image
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# ── SMTP (reset de clave / verificación) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=LasaEdu <no-reply@lasaacademy.cloudteco.com>
