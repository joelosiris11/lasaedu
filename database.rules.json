{
  "rules": {
    ".read": false,
    ".write": false,
    "users": {
      ".read": "auth != null",
      ".indexOn": ["email", "role"],
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && ($uid === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        "passwordHash": {
          ".read": false,
          ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
        },
        "refreshTokens": {
          ".read": "auth != null && $uid === auth.uid",
          ".write": "auth != null && $uid === auth.uid"
        }
      }
    },
    "authSessions": {
      "$sessionId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "courses": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'teacher')",
      ".indexOn": ["instructorId", "status", "category", "level"],
      "$courseId": {
        ".write": "auth != null && (data.child('instructorId').val() === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin' || (root.child('users').child(auth.uid).child('role').val() === 'teacher' && !data.exists()))"
      }
    },
    "modules": {
      ".read": "auth != null",
      ".indexOn": ["courseId", "order"],
      "$moduleId": {
        ".write": "auth != null && (root.child('courses').child(data.child('courseId').val()).child('instructorId').val() === auth.uid || root.child('courses').child(newData.child('courseId').val()).child('instructorId').val() === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin')"
      }
    },
    "lessons": {
      ".read": "auth != null",
      ".indexOn": ["moduleId", "courseId", "order"],
      "$lessonId": {
        ".write": "auth != null && (root.child('courses').child(data.child('courseId').val()).child('instructorId').val() === auth.uid || root.child('courses').child(newData.child('courseId').val()).child('instructorId').val() === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin')"
      }
    },
    "sections": {
      ".read": "auth != null",
      ".indexOn": ["courseId", "instructorId", "status"],
      "$sectionId": {
        ".write": "auth != null && (data.child('instructorId').val() === auth.uid || newData.child('instructorId').val() === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin')"
      }
    },
    "enrollments": {
      ".read": "auth != null",
      ".indexOn": ["userId", "courseId", "sectionId", "status"],
      "$enrollmentId": {
        ".read": "auth != null && (data.child('userId').val() === auth.uid || root.child('courses').child(data.child('courseId').val()).child('instructorId').val() === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'teacher')",
        ".write": "auth != null && (newData.child('userId').val() === auth.uid || data.child('userId').val() === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'teacher')"
      }
    },
    "evaluations": {
      ".read": "auth != null",
      ".indexOn": ["courseId", "moduleId", "status", "createdBy"],
      "$evaluationId": {
        ".write": "auth != null && (root.child('courses').child(data.child('courseId').val()).child('instructorId').val() === auth.uid || data.child('createdBy').val() === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'teacher')"
      }
    },
    "evaluationAttempts": {
      ".read": "auth != null",
      ".indexOn": ["userId", "evaluationId", "courseId"],
      "$attemptId": {
        ".read": "auth != null && (data.child('userId').val() === auth.uid || root.child('courses').child(data.child('courseId').val()).child('instructorId').val() === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'teacher')",
        ".write": "auth != null && (newData.child('userId').val() === auth.uid || data.child('userId').val() === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'teacher')"
      }
    },
    "grades": {
      ".read": "auth != null",
      ".indexOn": ["studentId", "courseId", "teacherId", "evaluationId"],
      "$gradeId": {
        ".read": "auth != null && (data.child('studentId').val() === auth.uid || data.child('teacherId').val() === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && (data.child('teacherId').val() === auth.uid || newData.child('teacherId').val() === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin')"
      }
    },
    "certificates": {
      ".read": "auth != null",
      ".indexOn": ["userId", "courseId", "credentialId"],
      "$certificateId": {
        ".read": "auth != null && (data.child('userId').val() === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'teacher')",
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'teacher')"
      }
    },
    "conversations": {
      ".read": "auth != null",
      ".indexOn": ["type", "courseId"],
      "$conversationId": {
        ".read": "auth != null && (data.child('participants').hasChild(auth.uid) || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && (data.child('participants').hasChild(auth.uid) || newData.child('participants').hasChild(auth.uid) || newData.child('createdBy').val() === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin')"
      }
    },
    "messages": {
      ".read": "auth != null",
      ".indexOn": ["conversationId", "senderId"],
      "$messageId": {
        ".read": "auth != null && (root.child('conversations').child(data.child('conversationId').val()).child('participants').hasChild(auth.uid) || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && (newData.child('senderId').val() === auth.uid || data.child('senderId').val() === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin')"
      }
    },
    "notifications": {
      ".indexOn": ["userId", "type", "read"],
      "$notificationId": {
        ".read": "auth != null && (data.child('userId').val() === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && (newData.child('userId').val() === auth.uid || data.child('userId').val() === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin')"
      }
    },
    "supportTickets": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'support')",
      ".indexOn": ["userId", "status", "assignedTo", "priority", "category"],
      "$ticketId": {
        ".read": "auth != null && (data.child('userId').val() === auth.uid || data.child('assignedTo').val() === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'support')",
        ".write": "auth != null && (newData.child('userId').val() === auth.uid || data.child('userId').val() === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'support')"
      }
    },
    "activities": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null",
      ".indexOn": ["userId", "type", "timestamp"],
      "$activityId": {
        ".read": "auth != null && (data.child('userId').val() === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin')"
      }
    },
    "userSettings": {
      ".indexOn": ["userId"],
      "$settingsId": {
        ".read": "auth != null && (data.child('userId').val() === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && (newData.child('userId').val() === auth.uid || data.child('userId').val() === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin')"
      }
    },
    "systemMetrics": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'teacher')",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".indexOn": ["date"]
    }
  }
}
