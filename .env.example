# Firebase Configuration
# Copy this file to .env and fill in credentials from the TARGET Firebase
# project (Firebase Console → Project settings → your Web app).
# Do not reuse values from the previous lasaedu-5d7c3 project.

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your_project.firebaseio.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Optional: Analytics
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# App Configuration
VITE_APP_NAME=LasaEdu
VITE_APP_URL=http://localhost:5173
VITE_USE_FIREBASE=true

# AI Assistant (admin-only content editor at /ai-assistant).
# The Ollama API key lives on the FILE SERVER (server/.env: OLLAMA_API_KEY=...),
# not in the browser bundle. The browser calls /ai/chat which the server
# proxies to Ollama Cloud after verifying the Firebase admin token.
# Model id; defaults to kimi-k2.6:cloud (Kimi K2.6) if unset.
VITE_OLLAMA_MODEL=kimi-k2.6:cloud
# Optional: override the proxy URL (default same-origin /ai/chat).
# VITE_AI_PROXY_URL=/ai/chat
# Unsplash: register an app at https://unsplash.com/developers
VITE_UNSPLASH_ACCESS_KEY=

# Admin seed (scripts/seed-admins.mjs) — NOT used by the Vite app, only by the
# CLI seed. Point GOOGLE_APPLICATION_CREDENTIALS at a service-account JSON
# (download from Firebase Console → Project settings → Service accounts).
# Keep the JSON OUTSIDE the repo.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
ADMIN_ROSARIO_PASSWORD=
ADMIN_LORENZO_PASSWORD=
